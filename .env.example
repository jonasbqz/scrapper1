# Server (local dev: keep in sync with lector-comics BASE_URL)
PORT=8887
NODE_ENV=production
CORS_ORIGIN=https://mangolibreria.com,https://www.mangolibreria.com,https://download.mangolibreria.com,http://localhost:3000,http://localhost:5499

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Shared pg pool tuning (monline-api + better-auth share one pool per container)
# With Dokploy replicas, each container opens its own pool. Example for 2 replicas:
#   APP_REPLICA_COUNT=2
#   DB_CONNECTION_BUDGET=24   # total budget for monline-api across replicas
#   => auto max=12 per container (or set DB_POOL_MAX=10 manually)
APP_REPLICA_COUNT=1
DB_CONNECTION_BUDGET=24
DB_POOL_MAX=
DB_POOL_MIN=1
DB_CONNECTION_TIMEOUT_MS=15000
DB_IDLE_TIMEOUT_MS=30000

# JWT (Better Auth JWKS served by the Next.js BFF)
JWT_JWKS_URL=https://mangolibreria.com/api/auth/jwks

# Internal BFF → API secret (required in production; must match lector-comics INTERNAL_ROUTE_SECRET)
INTERNAL_ROUTE_SECRET=generate-a-different-long-random-secret

# Scraper config
SCRAPER_DELAY_MS=100
SCRAPER_RUN_ON_STARTUP=false
SCRAPER_ENABLE_CRON=true
SCRAPER_IKIGAI_URL=https://refered-worker.techcometserver.workers.dev

BASE_URL=https://api.mangolibreria.com
FRONTEND_URL=https://mangolibreria.com

# Better Auth (Bearer token validation on the API)
BETTER_AUTH_SECRET=generate-a-long-random-secret
COOKIE_SECRET=generate-another-long-random-secret
# Solo las cuentas creadas desde esta fecha pueden expirar por no verificar en 24 horas.
EMAIL_VERIFICATION_REQUIRED_FROM=2026-04-04T00:00:00Z
DISCORD_CLIENT_ID=someclientid
DISCORD_CLIENT_SECRET=sometestclientsecret

# Admin authorization
# Comma-separated allowlists used by AdminGuard for operational endpoints.
ADMIN_USER_IDS=
ADMIN_EMAILS=

# Stripe subscriptions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_IDS=
STRIPE_PREMIUM_PRODUCT_IDS=
STRIPE_PREMIUM_PRICE_ID_1W=
STRIPE_PREMIUM_PRICE_ID_1M=
STRIPE_PREMIUM_PRICE_ID_3M=
STRIPE_PREMIUM_PRICE_ID_6M=
MONLINE_ADMIN_API_KEY=

# Storage (S3-compatible: Cloudflare R2 or Amazon S3)
# Importante: el bucket debe permitir CORS para PUT/GET/HEAD desde el frontend
# y aceptar el header Content-Type si se usan uploads directos desde navegador.
STORAGE_PROVIDER=r2
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Search rate limits (429). Pagination no longer shares the same bucket as brand-new searches.
SEARCH_RATE_NEW_PER_MINUTE=20
SEARCH_RATE_PAGINATION_PER_30S=50
SEARCH_RATE_SAME_QUERY_REFRESH_PER_30S=20
SEARCH_HUMAN_ENGAGEMENT_BONUS=2
SEARCH_AUTHENTICATED_BONUS=2
SEARCH_ENGAGEMENT_TTL_MS=300000

# Traffic events / bot learning. Risk signals are observed; only hard bursts get temporary fake-404 blocks.
TRAFFIC_EVENTS_ENABLED=true
# Origins allowed in Referer for browser traffic (defaults to CORS_ORIGIN when unset)
TRUSTED_REFERER_ORIGINS=https://mangolibreria.com,https://www.mangolibreria.com,https://download.mangolibreria.com
TRAFFIC_EVENTS_PERSIST_ENABLED=true
# Max concurrent background traffic writes to avoid saturating the DB pool
TRAFFIC_PERSIST_CONCURRENCY=3
# Contabo AS51167 is watchlisted for higher risk scoring when the CDN forwards ASN.
# Cloudflare origin transform recommended: set x-client-asn from cf.asn.
BOT_WATCH_ASNS=51167
# Optional comma-separated CIDR/IP list for confirmed suspicious ranges.
BOT_WATCH_IP_CIDRS=
# Persist only throttled raw evidence. Aggregates are always stored in hourly windows.
TRAFFIC_RAW_MIN_RISK_SCORE=35
TRAFFIC_RAW_SAMPLE_RATE=0.002
TRAFFIC_RAW_THROTTLE_MS=30000
TRAFFIC_RAW_RETENTION_DAYS=2
TRAFFIC_AGGREGATE_RETENTION_DAYS=30
# Inline blocking: datacenter/watchlist signals are observed; only hard request/search bursts return temporary fake 404s.
BOT_BLOCK_DATACENTER=true
BOT_BLOCK_FAST_REQUESTS=true
BOT_MAX_REQUESTS_PER_30S=200
BOT_MAX_SEARCHES_PER_30S=10
BOT_BLOCK_MAX_REQUESTS_PER_30S=250
BOT_BLOCK_MAX_SEARCHES_PER_30S=25
BOT_BLOCK_MAX_REQUESTS_PER_HOUR=1500
BOT_BLOCK_MAX_REQUESTS_PER_DAY=12000
BOT_BLOCK_TTL_HOURS=1
BOT_MAX_REQUESTS_PER_MINUTE=120
BOT_MAX_SEARCHES_PER_MINUTE=30
BOT_MAX_CONTENT_VIEWS_PER_MINUTE=80
BOT_MAX_UNIQUE_PATHS_10M=80
BOT_MAX_UNIQUE_SEARCHES_10M=40
# Optional allowlists for your own networks / trusted providers.
BOT_ALLOW_IPS=204.168.138.51,159.69.240.10
BOT_ALLOW_IP_CIDRS=
BOT_ALLOW_ASNS=15169

# Server
PORT=8885
NODE_ENV=production
CORS_ORIGIN=https://mangolibreria.com,http://localhost:3000,https://api.mangolibreria.com,https://wwww.mangolibreria.com

# Database
DATABASE_URL=postgresql://servedb:tsG54ZdXfgh0izDyST8v@159.69.240.10:5668/postgres

# JWT
JWT_JWKS_URL=https://mangolibreria.com/api/auth/jwks

# Scraper config
SCRAPER_DELAY_MS=100
SCRAPER_IKIGAI_URL=https://refered-worker.techcometserver.workers.dev

BASE_URL=https://api.mangolibreria.com
FRONTEND_URL=https://mangolibreria.com

# Better Auth
BETTER_AUTH_SECRET=testsecretkey
# Solo las cuentas creadas desde esta fecha pueden expirar por no verificar en 24 horas.
EMAIL_VERIFICATION_REQUIRED_FROM=2026-04-04T00:00:00Z
DISCORD_CLIENT_ID=someclientid
DISCORD_CLIENT_SECRET=sometestclientsecret

# Admin authorization
# Comma-separated allowlists used by AdminGuard for operational endpoints.
ADMIN_USER_IDS=
ADMIN_EMAILS=

# Stripe subscriptions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_IDS=
STRIPE_PREMIUM_PRODUCT_IDS=
STRIPE_PREMIUM_PRICE_ID_1W=
STRIPE_PREMIUM_PRICE_ID_1M=
STRIPE_PREMIUM_PRICE_ID_3M=
STRIPE_PREMIUM_PRICE_ID_6M=
MONLINE_ADMIN_API_KEY=

# Storage (S3-compatible: Cloudflare R2 or Amazon S3)
# Importante: el bucket debe permitir CORS para PUT/GET/HEAD desde el frontend
# y aceptar el header Content-Type si se usan uploads directos desde navegador.
STORAGE_PROVIDER=r2
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
